# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Azure AD / Microsoft Entra ID
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET_VALUE=your-client-secret

# PostgreSQL Database (Main Application)
DIGITAL_SIGNAGE_DB_NAME=digital_signage
DIGITAL_SIGNAGE_DB_HOST=localhost
DIGITAL_SIGNAGE_DB_USER=your-db-user
DIGITAL_SIGNAGE_DB_PASSWORD=your-db-password
DIGITAL_SIGNAGE_DB_PORT=5432

# PostgreSQL Database (Data Connect - for sales data)
DATA_CONNECT_DB_NAME=data_connect
DATA_CONNECT_DB_HOST=localhost
DATA_CONNECT_DB_USER=your-db-user
DATA_CONNECT_DB_PASSWORD=your-db-password
DATA_CONNECT_DB_PORT=5432

# Redis (optional - for caching/sessions)
# REDIS_URL=redis://localhost:6379/0

# CSRF Trusted Origins (for production)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://digital-signage.azurewebsites.net

# Digital Signage API Key (for external integrations like ScreenCloud)
SIGNAGE_API_KEY=your-api-key-here
